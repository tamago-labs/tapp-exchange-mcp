# Tapp Exchange MCP Server Environment Configuration

# Network Configuration (mainnet, testnet, devnet)
TAPP_NETWORK=mainnet

# Optional: Custom RPC URL (if not using default for network)
# TAPP_RPC_URL=https://fullnode.mainnet.aptoslabs.com/v1

# Private Key (optional - if not provided, a new random key will be generated)
# TAPP_PRIVATE_KEY=your_private_key_here

# API Configuration (optional)
# TAPP_API_TIMEOUT=30000
